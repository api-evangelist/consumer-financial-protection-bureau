        {
          "info": {
            "name": "Get a single complaint by ID",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://www.consumerfinance.gov/data-research/consumer-complaints/search/api/v1/:complaintId/",
            "params": [
              {
                "name": "complaintId",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Get a single complaint by ID"
        },
        {
          "info": {
            "name": "Autocomplete suggestions",
            "type": "http"
